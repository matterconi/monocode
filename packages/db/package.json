{
  "name": "@monocode/db",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --target node --outdir ./dist",
    "generate": "bunx --bun prisma generate",
    "push": "bunx --bun prisma db push",
    "seed": "bun prisma/seed.ts",
    "title:sessions": "bun scripts/title-sessions.ts",
    "studio": "bunx --bun prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-pg": "latest",
    "@prisma/client": "latest",
    "dotenv": "latest",
    "pg": "latest",
    "prisma": "latest"
  },
  "devDependencies": {
    "@types/pg": "latest"
  }
}
