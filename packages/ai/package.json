{
  "name": "@monocode-ai/ai",
  "version": "0.0.1",
  "private": false,
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --target node --format esm --outfile ./dist/index.mjs"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ai": "^6.0.175",
    "zod": "^4.4.3"
  }
}
