{
  "name": "monocode",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "bun run --cwd packages/db generate",
    "server": "bun run --filter @monocode/server dev",
    "cli": "MONOCODE_WORKSPACE_ROOT=\"$PWD\" bun run --cwd apps/cli dev",
    "web": "bun run --cwd apps/web dev",
    "check": "fallow dead-code && fallow dupes",
    "test": "bun run --filter \"*\" test"
  },
  "trustedDependencies": ["prisma"],
  "dependencies": {
    "@ai-sdk/groq": "^3.0.39",
    "@clerk/backend": "^3.4.13",
    "@hono/zod-validator": "^0.7.6",
    "@monocode-ai/ai": "workspace:*",
    "@monocode/db": "workspace:*",
    "@monocode/server": "workspace:*",
    "ai": "^6.0.175",
    "hono": "latest",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "fallow": "^2.64.0"
  }
}
